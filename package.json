{
  "name": "deckgen",
  "type": "module",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n client,server -c cyan,magenta \"npm run dev -w client\" \"npm run dev -w server\"",
    "build": "npm run build -w client && npm run build -w server",
    "lint": "eslint client/src server/src",
    "format": "prettier --write \"client/src/**/*.{ts,tsx,css}\" \"server/src/**/*.ts\""
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "eslint": "^9.21.0",
    "typescript-eslint": "^8.26.0",
    "@eslint/js": "^9.21.0",
    "prettier": "^3.5.3"
  }
}
